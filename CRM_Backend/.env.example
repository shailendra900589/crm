# Copy to .env and adjust as needed
SECRET_KEY=change-me-in-production
DEBUG=True

# --- SQLite (default local dev) ---
USE_POSTGRES=0

# --- PostgreSQL (docker compose or managed DB) ---
# USE_POSTGRES=1
# POSTGRES_DB=crm_db
# POSTGRES_USER=crm
# POSTGRES_PASSWORD=crm
# POSTGRES_HOST=127.0.0.1
# POSTGRES_PORT=5432

# --- Redis (WebSocket + Celery) ---
# REDIS_URL=redis://127.0.0.1:6379/0
CELERY_ALWAYS_EAGER=1

# Production deploy: see DEPLOY.md and .env.prod.example
# Docker full stack (dev): scripts/docker-dev.ps1 -FullStack

# --- Hosts (production) ---
# ALLOWED_HOSTS=crm.example.com
# CORS_ALLOWED_ORIGINS=https://crm.example.com
# CSRF_TRUSTED_ORIGINS=https://crm.example.com
# USE_HTTPS=1

# Email digest (console backend prints to Django/Celery logs by default)
# DIGEST_ENABLED=1
# FRONTEND_URL=http://127.0.0.1:3000
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=1
# DEFAULT_FROM_EMAIL=Amazon Merchant CRM <noreply@crm.local>

# AWS S3 (set USE_S3=1 to store uploads in S3 instead of local disk)
# USE_S3=1
# AWS_ACCESS_KEY_ID=your-key
# AWS_SECRET_ACCESS_KEY=your-secret
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_S3_REGION_NAME=ap-south-1
# AWS_S3_CUSTOM_DOMAIN=
