# =============================================================================
# CRM production env — https://crm.trackbook.co
# On server:  cp .env.prod.example .env.prod && nano .env.prod
# Then set SECRET_KEY + POSTGRES_PASSWORD (required). Keep other lines as-is.
# =============================================================================

# --- REQUIRED (must change) ---
SECRET_KEY=REPLACE_WITH_OPENSSL_RAND_HEX_32
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD

# --- Database: PostgreSQL (NOT MongoDB) ---
POSTGRES_DB=crm_db
POSTGRES_USER=crm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Domain (same URL for frontend + API) ---
ALLOWED_HOSTS=crm.trackbook.co,www.crm.trackbook.co,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://crm.trackbook.co,https://www.crm.trackbook.co
CSRF_TRUSTED_ORIGINS=https://crm.trackbook.co,https://www.crm.trackbook.co
FRONTEND_URL=https://crm.trackbook.co

# --- App (keep these ON — do not comment them out) ---
DEBUG=False
DIGEST_ENABLED=1
LOG_LEVEL=INFO
RUN_SEED=1
HTTP_PORT=80
USE_HTTPS=1

# --- Optional email (leave commented until SMTP is ready) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=1
# DEFAULT_FROM_EMAIL=Amazon Merchant CRM <noreply@crm.trackbook.co>

# --- Optional S3 uploads (leave commented to use local Docker volume) ---
# USE_S3=1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=ap-south-1
