# Copy to .env.prod and fill in secrets before deploying:
#   copy .env.prod.example .env.prod

# --- Required ---
SECRET_KEY=change-me-to-a-long-random-string
POSTGRES_PASSWORD=change-me-strong-db-password

# --- Database (PostgreSQL — this project does NOT use MongoDB) ---
POSTGRES_DB=crm_db
POSTGRES_USER=crm
# Leave POSTGRES_HOST unset (or =postgres) for Docker Postgres on same EC2.
# For Amazon RDS, set the endpoint and use docker-compose.aws.yml (see AWS_DEPLOY.md).
# POSTGRES_HOST=postgres
# POSTGRES_PORT=5432

# --- Hosts / CORS (production domain: https://crm.trackbook.co) ---
ALLOWED_HOSTS=crm.trackbook.co,www.crm.trackbook.co,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://crm.trackbook.co,https://www.crm.trackbook.co
CSRF_TRUSTED_ORIGINS=https://crm.trackbook.co,https://www.crm.trackbook.co
FRONTEND_URL=https://crm.trackbook.co

# --- App ---
DEBUG=False
DIGEST_ENABLED=1
LOG_LEVEL=INFO
# Seed demo users on first boot (admin/manager/tl/bdm · password123). Set 0 after first deploy.
RUN_SEED=1

# --- HTTP port published by nginx ---
HTTP_PORT=80

# --- HTTPS (TLS terminated at Cloudflare / host proxy in front of nginx) ---
USE_HTTPS=1
# SECURE_SSL_REDIRECT=0

# --- Email (optional; console logs by default) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# EMAIL_USE_TLS=1
# DEFAULT_FROM_EMAIL=Amazon Merchant CRM <noreply@crm.trackbook.co>

# --- S3 media (optional) ---
# USE_S3=1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=ap-south-1
